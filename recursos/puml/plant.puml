@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Usuario" as U
actor "Administrador" as A

package "Aplicación" {
  usecase "Iniciar sesión" as UC1
  usecase "Cerrar sesión" as UC2
  usecase "Registrarse" as UC3
  usecase "Borrar cuenta" as UC4
  usecase "Cambiar ajustes" as UC5
}

package "Social" {
  usecase "Editar perfil" as UC6
  usecase "Buscar perfiles" as UC7
  usecase "Seguir perfiles" as UC8
  usecase "Ver logros disponibles" as UC9
}

package "Librería" {
  usecase "Buscar contenido" as UC10
  usecase "Añadir contenido a la lista" as UC11
  usecase "Puntuar contenido" as UC12
  usecase "Actualizar progreso" as UC13
  usecase "Ver lista de contenidos" as UC14
  usecase "Guardar para ver más tarde" as UC15
  usecase "Eliminar contenido de la lista" as UC16
  usecase "Descubrir contenido" as UC17
}

package "Administración" {
  usecase "Eliminar usuarios" as UC18
  usecase "Bloquear usuarios" as UC19
  usecase "Crear/Editar logros" as UC20
}

' Relaciones para Usuario
U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5

U --> UC6
U --> UC7
U --> UC8
U --> UC9

U --> UC10
U --> UC11
U --> UC12
U --> UC13
U --> UC14
U --> UC15
U --> UC16
U --> UC17

' Relaciones para Administrador
A --> UC18
A --> UC19
A --> UC20

@enduml
